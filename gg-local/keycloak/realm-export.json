{
  "realm": "gg",
  "enabled": true,
  "displayName": "GG Gaming",
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "roles": {
    "realm": [
      { "name": "customer", "description": "Standard shopper" },
      { "name": "admin", "description": "Store administrator" }
    ]
  },
  "clients": [
    {
      "clientId": "gg-storefront",
      "name": "GG Storefront BFF",
      "description": "Confidential client for the Next.js BFF. Uses Direct Access Grants (password) for the custom branded login, and a service account for user registration via the Admin API.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "gg-storefront-dev-secret",
      "clientAuthenticatorType": "client-secret",
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "fullScopeAllowed": true,
      "redirectUris": ["http://localhost:3000/*"],
      "webOrigins": ["http://localhost:3000"],
      "attributes": { "access.token.lifespan": "300" }
    }
  ],
  "users": [
    {
      "username": "service-account-gg-storefront",
      "enabled": true,
      "serviceAccountClientId": "gg-storefront",
      "clientRoles": {
        "realm-management": ["manage-users", "view-users", "query-users"]
      }
    },
    {
      "username": "demo",
      "email": "demo@gg.dev",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Demo",
      "lastName": "Gamer",
      "credentials": [
        { "type": "password", "value": "demo12345", "temporary": false }
      ],
      "realmRoles": ["customer"]
    },
    {
      "username": "admin",
      "email": "admin@gg.dev",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Store",
      "lastName": "Admin",
      "credentials": [
        { "type": "password", "value": "admin12345", "temporary": false }
      ],
      "realmRoles": ["admin"]
    }
  ]
}
