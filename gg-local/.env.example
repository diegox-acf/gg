# gg-local — Docker Compose environment.
#
# Copy to `.env` (gitignored) and fill in real secrets:  cp .env.example .env
# Compose reads `.env` automatically for ${VAR} substitution in docker-compose.yml.
# Every var has a safe dev default in the compose file, so the stack runs even with
# blanks — only Stripe needs real values for checkout to complete.

# ── Postgres (shared by the catalog / inventory / orders databases) ──────────────
# NOTE: a password change only takes effect on a FRESH volume
# (docker compose down -v), since Postgres sets it on first init.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── Keycloak database ────────────────────────────────────────────────────────────
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=keycloak

# ── Keycloak bootstrap admin (the admin console at http://localhost:8081) ─────────
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# ── Keycloak `gg` realm client secret (the gg-storefront client) ──────────────────
# Used by both the storefront and admin BFFs. Matches the realm export.
KEYCLOAK_CLIENT_SECRET=gg-storefront-dev-secret

# ── Auth.js session secret (storefront + admin) ──────────────────────────────────
# Generate a real one with:  openssl rand -base64 32
AUTH_SECRET=dev-insecure-secret-change-me

# ── Stripe (test mode) — https://dashboard.stripe.com/test/apikeys ───────────────
# Leave blank to run without checkout; fill in to exercise payments.
# Secret key, format: sk_test_<...>  (orders: outbound API calls)
STRIPE_API_KEY=
# Webhook signing secret, format: whsec_<...>
# (printed by `stripe listen --forward-to localhost:8083/webhooks/stripe`)
STRIPE_WEBHOOK_SECRET=
# Publishable key, format: pk_test_<...> — inlined into the storefront bundle at
# BUILD time, so rebuild after changing:  docker compose build storefront
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
