# Copy to .env.local for local dev. .env.local is gitignored.

# --- Auth.js (NextAuth v5) ---
# Generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=replace-me-with-a-random-32-byte-base64-string

# --- Keycloak (realm `gg`, see ADR-017) ---
KEYCLOAK_ISSUER=http://localhost:8081/realms/gg
KEYCLOAK_CLIENT_ID=gg-storefront
KEYCLOAK_CLIENT_SECRET=gg-storefront-dev-secret

# --- Downstream services ---
CATALOG_API_URL=http://localhost:8080
ORDERS_API_URL=http://localhost:8083

# --- Stripe (test mode) — checkout payment (Milestone E, ADR-021) ---
# Publishable key is sent to the browser (NEXT_PUBLIC_), used by Stripe Elements.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace-me

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=gg-storefront-bff

# --- Redis (cart, Increment C) ---
REDIS_URL=redis://localhost:6379
