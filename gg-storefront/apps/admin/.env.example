# Admin console (apps/admin) — runs on http://localhost:3002

# Auth.js — must be set; generate with `openssl rand -base64 32`
AUTH_SECRET=

# Keycloak `gg` realm (shared client with the storefront)
KEYCLOAK_ISSUER=http://localhost:8081/realms/gg
KEYCLOAK_CLIENT_ID=gg-storefront
KEYCLOAK_CLIENT_SECRET=gg-storefront-dev-secret

# Backend services (admin reads)
CATALOG_API_URL=http://localhost:8080
INVENTORY_API_URL=http://localhost:8082
ORDERS_API_URL=http://localhost:8083

# OpenTelemetry (OTLP/HTTP collector); exporter appends /v1/traces
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
